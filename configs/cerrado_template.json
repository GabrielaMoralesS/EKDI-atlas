{
  "project_name": "EKDI Atlas - Cerrado Template",
  "biome_name": "Cerrado",
  "grid_resolution_km": 5,
  "current_year": 2026,
  "status": "template_requires_local_inputs",
  "notes": "This configuration documents the inputs required to run EKDI for Cerrado. It does not contain computed Cerrado outputs.",
  "overwrite_existing_outputs": false,
  "weights": {
    "sampling_antiquity": 0.45,
    "post_record_forest_loss": 0.35,
    "richness_deficit": 0.2
  },
  "thresholds": {
    "critical_percentile": 0.9
  },
  "inputs": {
    "grid": "data/cerrado/grid_final.gpkg",
    "gbif_joined": "data/cerrado/gbif_grid_joined.parquet",
    "endemism_grid": "data/cerrado/grid_endemicas.gpkg",
    "ghost_species": "data/cerrado/ghost_species.csv",
    "extinction_risk_analysis": "data/cerrado/extinction_risk_analysis.csv",
    "forest_loss_grid": "data/cerrado/perdida_forestal_por_celda.gpkg",
    "richness_deficit_grid": "data/cerrado/deficit_riqueza_por_celda.gpkg"
  },
  "outputs": {
    "priority_cells": "outputs/cerrado/app/data/geo/priority_cells.geojson",
    "state_summary": "outputs/cerrado/app/data/tables/state_summary.json",
    "scientific_report": "outputs/cerrado/app/data/metadata/scientific_report.json"
  },
  "provenance": {
    "gbif_download_doi": "required",
    "habitat_change_source": "required",
    "notes": "Atlantic Forest weights are only placeholders here. Cerrado weights should be calibrated before interpretation."
  }
}
